PORT=3000

# ── Redis ────────────────────────────────────────────────────────────────────
# REDIS_URL 하나로 설정하거나 아래 개별 항목으로 설정
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true

# ── 세션 ─────────────────────────────────────────────────────────────────────
# 운영 환경에서는 반드시 강력한 랜덤 문자열로 교체하세요.
# 예) openssl rand -hex 32
SESSION_SECRET=your-strong-random-secret-here
SESSION_MAX_AGE=604800000   # 7일 (밀리초)

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# 발급처: https://console.cloud.google.com/apis/credentials
# 1. 프로젝트 생성 → OAuth 동의 화면 설정
# 2. 사용자 인증 정보 → OAuth 2.0 클라이언트 ID 생성
# 3. 승인된 리디렉션 URI에 GOOGLE_CALLBACK_URL 추가
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── Kakao OAuth ───────────────────────────────────────────────────────────────
# 발급처: https://developers.kakao.com/console/app
# 1. 애플리케이션 추가 → 앱 키 → REST API 키 복사
# 2. 카카오 로그인 → 활성화 ON
# 3. Redirect URI에 KAKAO_CALLBACK_URL 등록
# 4. 동의 항목: 닉네임, 프로필 사진, 카카오계정(이메일) 설정
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=     # 보안 강화 시 설정 (선택)
KAKAO_CALLBACK_URL=http://localhost:3000/auth/kakao/callback

# ── 소켓 CORS ─────────────────────────────────────────────────────────────────
SOCKET_ALLOW_ORIGINS=http://localhost:3000
CLIENT_SOCKET_SERVER_URL=
